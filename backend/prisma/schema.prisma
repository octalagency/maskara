generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  MERCHANT_OWNER
  MERCHANT_STAFF
}

enum MerchantStatus {
  ACTIVE
  SUSPENDED
  TRIAL
  CANCELLED
}

enum SubscriptionPlan {
  FREE
  STARTER
  GROWTH
  ENTERPRISE
}

enum BillingStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum OrderStatus {
  PENDING
  CALLING
  VERIFIED
  CANCELLED
  FAILED
  ESCALATED
}

enum CallStatus {
  QUEUED
  RINGING
  IN_PROGRESS
  COMPLETED
  FAILED
  NO_ANSWER
  BUSY
  CANCELLED
}

enum CallOutcome {
  CONFIRMED
  CANCELLED
  ESCALATED
  NO_RESPONSE
  INVALID_INPUT
}

enum IntegrationType {
  SHOPIFY
  WOOCOMMERCE
  CUSTOM_API
  FACEBOOK
}

enum NotificationType {
  EMAIL
  SMS
  WHATSAPP
  WEBHOOK
  IN_APP
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  firstName     String
  lastName      String
  phone         String?
  role          UserRole  @default(MERCHANT_OWNER)
  isActive      Boolean   @default(true)
  emailVerified Boolean   @default(false)
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  merchantId String?
  merchant   Merchant? @relation(fields: [merchantId], references: [id])

  refreshTokens RefreshToken[]
  authTokens    AuthToken[]
  auditLogs     AuditLog[]

  @@index([merchantId])
  @@index([email])
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

enum AuthTokenType {
  EMAIL_VERIFY
  PASSWORD_RESET
}

model AuthToken {
  id        String        @id @default(cuid())
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String        @unique
  type      AuthTokenType
  expiresAt DateTime
  createdAt DateTime      @default(now())

  @@index([userId])
  @@index([token])
}

model Merchant {
  id               String           @id @default(cuid())
  name             String
  slug             String           @unique
  email            String
  phone            String
  website          String?
  logo             String?
  status           MerchantStatus   @default(TRIAL)
  subscriptionPlan SubscriptionPlan @default(FREE)
  subscriptionEnds DateTime?
  timezone         String           @default("Asia/Dhaka")
  currency         String           @default("BDT")

  // Voice settings
  voiceLanguage    String  @default("bn-BD")
  storeNameBangla  String?
  customGreeting   String?  // Call script / custom_text for AI verification
  voiceId          String?  // e.g. "azure:bn-BD-NabanitaNeural" or "google:bn-IN-Chirp3-HD-Algieba"
  speechRate       Float?   @default(0.95) // Google TTS speakingRate — call-center default ~0.95

  // Notification settings
  smsEnabled       Boolean @default(true)
  whatsappEnabled  Boolean @default(false)
  emailEnabled     Boolean @default(true)
  webhookUrl       String?
  webhookSecret    String?

  // Retry settings — ASAP + 2min retry + 8 staggered/day (08:00–22:00 BD)
  maxCallRetries   Int @default(10)
  retryIntervalMin Int @default(90)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users         User[]
  apiKeys       ApiKey[]
  integrations  Integration[]
  orders        Order[]
  calls         Call[]
  notifications Notification[]
  usageRecords  UsageRecord[]
  subscriptions Subscription[]
  billingRecords BillingRecord[]
  paymentSessions PaymentSession[]

  @@index([slug])
  @@index([status])
}

model Plan {
  id           String   @id @default(cuid())
  code         String   @unique
  name         String
  nameBangla   String?
  description  String?
  priceMonthly Decimal  @db.Decimal(10, 2)
  currency     String   @default("BDT")
  callLimit    Int
  smsLimit     Int
  trialDays    Int      @default(14)
  features     Json     @default("[]")
  isActive     Boolean  @default(true)
  isPopular    Boolean  @default(false)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model BillingRecord {
  id            String        @id @default(cuid())
  merchantId    String
  merchant      Merchant      @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  planCode      String
  amount        Decimal       @db.Decimal(10, 2)
  currency      String        @default("BDT")
  periodStart   DateTime
  periodEnd     DateTime
  status        BillingStatus @default(PENDING)
  paymentMethod String?
  paymentRef    String?
  notes         String?
  createdAt     DateTime      @default(now())

  @@index([merchantId])
  @@index([status])
  @@index([createdAt])
}

enum PaymentProvider {
  BKASH
  NAGAD
  MANUAL
}

enum PaymentSessionStatus {
  CREATED
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

model PaymentSession {
  id           String               @id @default(cuid())
  merchantId   String
  merchant     Merchant             @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  billingId    String?
  provider     PaymentProvider
  amount       Decimal              @db.Decimal(10, 2)
  currency     String               @default("BDT")
  status       PaymentSessionStatus @default(CREATED)
  gatewayTrxId String?
  paymentUrl   String?
  callbackData Json?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime @updatedAt

  @@index([merchantId])
  @@index([billingId])
  @@index([status])
}

model ApiKey {
  id          String    @id @default(cuid())
  merchantId  String
  merchant    Merchant  @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  name        String
  keyHash     String    @unique
  keyPrefix   String
  permissions String[]  @default(["orders:write", "orders:read"])
  isActive    Boolean   @default(true)
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())

  @@index([merchantId])
  @@index([keyHash])
}

model Integration {
  id           String          @id @default(cuid())
  merchantId   String
  merchant     Merchant        @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  type         IntegrationType
  name         String
  isActive     Boolean         @default(true)
  credentials  Json?
  webhookUrl   String?
  lastSyncAt   DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([merchantId])
  @@index([type])
}

model Order {
  id              String      @id @default(cuid())
  merchantId      String
  merchant        Merchant    @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  externalId      String?
  orderNumber     String
  customerName    String
  customerPhone   String
  customerEmail   String?
  totalAmount     Decimal     @db.Decimal(12, 2)
  currency        String      @default("BDT")
  status          OrderStatus @default(PENDING)
  items           Json?
  shippingAddress Json?
  paymentMethod   String?
  notes           String?
  source          IntegrationType @default(CUSTOM_API)
  metadata        Json?
  verifiedAt      DateTime?
  cancelledAt     DateTime?
  callAttempts    Int         @default(0)
  /** When the next follow-up call should be queued (staggered per order). */
  nextCallAt      DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  calls         Call[]
  notifications Notification[]

  @@unique([merchantId, externalId])
  @@index([merchantId])
  @@index([status])
  @@index([customerPhone])
  @@index([createdAt])
  @@index([nextCallAt])
}

model Call {
  id              String      @id @default(cuid())
  merchantId      String
  merchant        Merchant    @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  orderId         String
  order           Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  twilioCallSid   String?     @unique
  provider        String?     // twilio | epbx | ippbx | simulate
  providerCallId  String?
  status          CallStatus  @default(QUEUED)
  outcome         CallOutcome?
  dtmfInput       String?
  duration        Int?
  recordingUrl    String?
  recordingS3Key  String?
  errorMessage    String?
  attemptNumber   Int         @default(1)
  startedAt       DateTime?
  endedAt         DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([merchantId])
  @@index([orderId])
  @@index([status])
  @@index([createdAt])
}

model Notification {
  id         String             @id @default(cuid())
  merchantId String
  merchant   Merchant           @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  orderId    String?
  order      Order?             @relation(fields: [orderId], references: [id], onDelete: SetNull)
  type       NotificationType
  status     NotificationStatus @default(PENDING)
  recipient  String
  subject    String?
  message    String
  metadata   Json?
  sentAt     DateTime?
  createdAt  DateTime           @default(now())

  @@index([merchantId])
  @@index([status])
}

model Subscription {
  id              String           @id @default(cuid())
  merchantId      String
  merchant        Merchant         @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  plan            SubscriptionPlan
  price           Decimal          @db.Decimal(10, 2)
  currency        String           @default("BDT")
  callLimit       Int
  callsUsed       Int              @default(0)
  smsLimit        Int              @default(0)
  smsUsed         Int              @default(0)
  startsAt        DateTime
  endsAt          DateTime
  isActive        Boolean          @default(true)
  paymentProvider String?
  paymentId       String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([merchantId])
  @@index([isActive])
}

model UsageRecord {
  id         String   @id @default(cuid())
  merchantId String
  merchant   Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  date       DateTime @db.Date
  callsMade  Int      @default(0)
  callsSuccess Int    @default(0)
  ordersReceived Int  @default(0)
  ordersVerified Int  @default(0)
  ordersCancelled Int @default(0)
  smsSent    Int      @default(0)
  createdAt  DateTime @default(now())

  @@unique([merchantId, date])
  @@index([merchantId])
  @@index([date])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action     String
  entity     String
  entityId   String?
  metadata   Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([entity])
  @@index([createdAt])
}

model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt
}
