# Maskara Production Environment
# Copy: cp .env.production.example .env

NODE_ENV=production
RUN_SEED=false
SEED_DEMO=false
NEXT_PUBLIC_PRODUCTION=true

# Database
POSTGRES_USER=maskara
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=maskara

# Security — generate: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_64_CHAR_RANDOM_SECRET
VOICE_WEBHOOK_SECRET=CHANGE_ME_VOICE_WEBHOOK_SECRET
WOOCOMMERCE_WEBHOOK_SECRET=CHANGE_ME_WOO_WEBHOOK_SECRET

# bKash / Nagad (sandbox URLs work without keys — mock mode)
BKASH_APP_KEY=
BKASH_APP_SECRET=
BKASH_USERNAME=
BKASH_PASSWORD=
BKASH_BASE_URL=https://tokenized.sandbox.bka.sh/v1.2.0-beta
NAGAD_MERCHANT_ID=
NAGAD_MERCHANT_NUMBER=
NAGAD_PUBLIC_KEY=
NAGAD_PRIVATE_KEY=
NAGAD_BASE_URL=http://sandbox.mynagad.com:10080/remote-payment-gateway-1.0

# Email (verification + password reset)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Maskara <noreply@maskara.bd>

# Monitoring + recordings + backups
SENTRY_DSN=
AWS_S3_BUCKET=maskara-recordings
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-southeast-1
BACKUP_S3_BUCKET=

# Domains (HTTPS required) — see docs/DOMAIN-SETUP.md
# maskara.bd → app.maskara.bd (redirect via nginx)
APP_URL=https://app.maskara.bd
API_URL=https://api.maskara.bd
PUBLIC_API_URL=https://api.maskara.bd
FRONTEND_URL=https://app.maskara.bd

# Voice (ePBX production)
VOICE_PROVIDER=epbx
EPBX_API_URL=https://maskara.epbx.bd/api/v1
EPBX_API_KEY=YOUR_EPBX_KEY
EPBX_CUSTOMER_ID=
EPBX_IVR_ID=

# Google Cloud Text-to-Speech (Chirp3 Algieba) — never commit the real key
GOOGLE_TTS_API_KEY=

# Google Cloud Text-to-Speech (Maskara-direct Chirp3 — set on VPS .env, never commit)
GOOGLE_TTS_API_KEY=

# Docker Hub
DOCKER_USERNAME=yourdockerhub
IMAGE_TAG=latest

# First admin (only for one-time seed)
# RUN_SEED=true
# ADMIN_EMAIL=admin@maskara.bd
# ADMIN_INITIAL_PASSWORD=CHANGE_ME_ON_FIRST_DEPLOY
