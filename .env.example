# Database
POSTGRES_USER=maskara
POSTGRES_PASSWORD=maskara_secret
POSTGRES_DB=maskara
DATABASE_URL=postgresql://maskara:maskara_secret@localhost:5432/maskara

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# App URLs
APP_URL=http://localhost:3000
API_URL=http://localhost:4000
FRONTEND_URL=http://localhost:3000
# Public HTTPS URL for ePBX/Twilio voice callbacks (required in production)
PUBLIC_API_URL=

# Webhook security (required in production)
VOICE_WEBHOOK_SECRET=
WOOCOMMERCE_WEBHOOK_SECRET=

# Voice Provider: auto | epbx | ippbx | twilio | simulate
VOICE_PROVIDER=auto

# ePBX.bd
EPBX_API_URL=https://epbx.bd/api/v1
EPBX_API_KEY=
EPBX_CUSTOMER_ID=
EPBX_IVR_ID=

# ippbx.com.bd
IPPBX_API_URL=
IPPBX_API_KEY=
IPPBX_API_SECRET=

# Twilio
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# bKash (https://developer.bka.sh)
BKASH_BASE_URL=https://tokenized.sandbox.bka.sh/v1.2.0-beta
BKASH_APP_KEY=
BKASH_APP_SECRET=
BKASH_USERNAME=
BKASH_PASSWORD=

# Nagad (https://nagad.com.bd)
NAGAD_BASE_URL=http://sandbox.mynagad.com:10080/remote-payment-gateway-1.0
NAGAD_MERCHANT_ID=
NAGAD_PRIVATE_KEY=

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Maskara <noreply@maskara.bd>

# Monitoring
SENTRY_DSN=

# AWS S3 (Call Recordings)
AWS_S3_BUCKET=maskara-recordings
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=ap-southeast-1

# Shopify
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=

# Production / seed (dev only)
RUN_SEED=false
SEED_DEMO=false
ADMIN_EMAIL=
ADMIN_INITIAL_PASSWORD=
DEMO_MERCHANT_PASSWORD=
NEXT_PUBLIC_PRODUCTION=false
